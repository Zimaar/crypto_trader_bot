# === ALTfins API ===
ALTFINS_API_KEY=your_altfins_api_key_here
ALTFINS_BASE_URL=https://altfins.com

# === Telegram Bot ===
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here
ALLOWED_TELEGRAM_USER_IDS=

# === WhatsApp (Optional — Meta Cloud API) ===
WHATSAPP_ENABLED=false
WHATSAPP_TOKEN=your_whatsapp_token_here
WHATSAPP_PHONE_ID=your_whatsapp_phone_number_id_here
WHATSAPP_TO_NUMBER=your_whatsapp_number_with_country_code

# === Market News (Optional — for /news and daily brief) ===
NEWSAPI_KEY=your_newsapi_key_here

# === OpenAI (Optional — AI analysis) ===
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini
OPENAI_REASONING_EFFORT=low
AI_ALERT_ANALYSIS_ENABLED=false

# === Bot Settings ===
MIN_SCORE_ALERT=7
MIN_SCORE_URGENT=9
MIN_MARKET_CAP=50000000
PREMIUM_SYMBOL_COOLDOWN_HOURS=6
MAX_PREMIUM_ALERTS_PER_SCAN=2
MAX_PREMIUM_ALERTS_PER_DAY=6
MARKET_DIGEST_INTERVAL_HOURS=4
MANAGED_SETUP_EXPIRY_HOURS=24
DIGEST_SYMBOL_SUPPRESSION_HOURS=12
DIGEST_SCORE_IMPROVEMENT_THRESHOLD=1
MAX_DIGEST_CANDIDATES=5
LIFECYCLE_POLL_INTERVAL_SECONDS=900
POLL_INTERVAL_BREAKOUTS_SECONDS=300
POLL_INTERVAL_MOMENTUM_SECONDS=600
PULLBACK_POLLING_ENABLED=false
TIMEZONE=Asia/Dubai
FOCUS_SYMBOLS=
DB_PATH=bot_data.db
